# Root reference env
# Use frontend/.env.local for frontend and backend/keeper/.env for keeper runtime.

# Frontend (copy to frontend/.env.local)
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_READ_RPC_URL=
NEXT_PUBLIC_PAYROLL_PROGRAM_ID=
NEXT_PUBLIC_INCO_PROGRAM_ID=
NEXT_PUBLIC_INCO_TOKEN_PROGRAM_ID=
NEXT_PUBLIC_MAGICBLOCK_DELEGATION_PROGRAM=
NEXT_PUBLIC_PAYUSD_MINT=
NEXT_PUBLIC_COMPLIANCE_ENABLED=false
# Optional (only if compliance enabled)
# NEXT_PUBLIC_RANGE_API_KEY=
# Optional MongoDB for assistant run-state persistence
# MONGODB_URI=
# MONGODB_DB_NAME=expensee

# Keeper (copy to backend/keeper/.env)
KEEPER_RPC_URL=
KEEPER_READ_RPC_URL=
KEEPER_ROUTER_RPC_URL=
KEEPER_PROGRAM_ID=
KEEPER_PAYER_KEYPAIR_PATH=
KEEPER_MAGIC_CONTEXT=
KEEPER_REDELEGATE_AFTER_WITHDRAW=true
KEEPER_COMPLIANCE_ENABLED=false
# Optional (only if compliance enabled)
# KEEPER_RANGE_API_KEY=
