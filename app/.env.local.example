# ==============================
# App Environment
# ==============================

# Required: RPC (base layer)
# Use a normal Solana devnet RPC for the web app. The MagicBlock router is only required for the keeper
# when committing/undelegating delegated accounts.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional: separate read RPC (fallback for reads)
NEXT_PUBLIC_SOLANA_READ_RPC_URL=https://api.devnet.solana.com

# Required: payroll + privacy programs
NEXT_PUBLIC_PAYROLL_PROGRAM_ID=97u6CxDck3yhEP6bcvjsMUeV6Us439Y7sSSBBj14QQuU
NEXT_PUBLIC_INCO_PROGRAM_ID=5sjEbPiqgZrYwR31ahR6Uk9wf5awoX61YGg7jExQSwaj
NEXT_PUBLIC_INCO_TOKEN_PROGRAM_ID=4cyJHzecVWuU2xux6bCAPAhALKQT8woBh4Vx3AGEGe5N
NEXT_PUBLIC_MAGICBLOCK_DELEGATION_PROGRAM=DELeGGvXpWV2fqJUhqcF5ZSYMS4JTLjteaAMARRSaeSh
NEXT_PUBLIC_MAGICBLOCK_MAGIC_PROGRAM=Magic11111111111111111111111111111111111111
NEXT_PUBLIC_MAGICBLOCK_MAGIC_CONTEXT=9c13Lsd7f7EMh2H7M2hADQ6S1Mv115eH3dYpxWvS12xQ
# ER validator (used for delegation + crank scheduling). NOT the same as the TEE identity.
NEXT_PUBLIC_MAGICBLOCK_VALIDATOR=MEUGGrYPxKk17hCr7wpT6s8dtNokZj5U2L57vjYMS8e
# TEE identity (separate from ER validator — only for token-gated TEE endpoint auth).
NEXT_PUBLIC_MAGICBLOCK_TEE_VALIDATOR=FnE6VJT5QNZdedZPnCoLsARgBwoE6DeJNjBs2H1gySXA
# ER router endpoint (used by scheduleCrankV4 and commitAndUndelegate).
NEXT_PUBLIC_MAGICBLOCK_ENDPOINT=https://devnet-router.magicblock.app
# Default ER region for the UI (eu/us/asia). Falls back to available regions if unset.
NEXT_PUBLIC_MAGICBLOCK_VALIDATOR_REGION=eu
# Optional region-specific validators for employer-side region selector.
NEXT_PUBLIC_MAGICBLOCK_VALIDATOR_US=
NEXT_PUBLIC_MAGICBLOCK_VALIDATOR_ASIA=
NEXT_PUBLIC_PAYUSD_MINT=REPLACE_WITH_DEVNET_MINT

# Required for fail-closed stream create path
# Compliance is disabled by default (devnet/local). Enable explicitly if you have a Range key.
NEXT_PUBLIC_COMPLIANCE_ENABLED=false
# Only required if NEXT_PUBLIC_COMPLIANCE_ENABLED=true
# NEXT_PUBLIC_RANGE_API_KEY=REPLACE_WITH_RANGE_API_KEY

# Optional: UI / debug
# TEE endpoint URL. Transactions are routed through this when TEE mode is enabled.
NEXT_PUBLIC_MAGICBLOCK_TEE_URL=https://tee.magicblock.app
# Set to true to enable TEE-signed transaction routing. Required in production.
NEXT_PUBLIC_MAGICBLOCK_TEE_ENABLED=true
NEXT_PUBLIC_DEBUG=false
# Optional: privacy salt for hashing employer/employee IDs before encryption.
# Leave empty to keep current behavior.
NEXT_PUBLIC_PRIVACY_ID_SALT=
# Setup script: auto-delegate new employees (PER). Set false to skip delegation.
SETUP_AUTO_DELEGATE=true
# Legacy consoles (disabled by default; set true to re-enable)
NEXT_PUBLIC_ENABLE_LEGACY_V2=false
NEXT_PUBLIC_ENABLE_LEGACY_V3=false

# Phase 2+3: Keeper relay API (claim auth + Ghost Mode withdraw-auth endpoints)
# Point to whatever host:port the keeper health server runs on.
NEXT_PUBLIC_KEEPER_API_URL=http://localhost:9090
# Strict privacy default: hide keeper view auto-grant UI unless explicitly enabled.
NEXT_PUBLIC_KEEPER_VIEW_RELAY=false
# Enable employee UI fallback to keeper-side live decrypt API (/api/reveal-live).
# Set to true when keeper is running with KEEPER_ENABLE_SERVER_DECRYPT=true.
NEXT_PUBLIC_KEEPER_SERVER_DECRYPT=true

# Optional: MongoDB persistence for AI assistant run state
# If set, assistant drafts/queues are restored after refresh/restart.
MONGODB_URI=
MONGODB_DB_NAME=expensee

# ==============================
# Public Entry/Exit Bridge (Devnet Demo)
# ==============================
# This enables a custodial "wrap/unwrap" so you can tell a real-world story:
# public token in/out, confidential payroll in the middle.
#
# IMPORTANT: This is NOT trustless. The backend must control escrow + confidential mint authority.

# Turn the /bridge page + API routes on/off
NEXT_PUBLIC_BRIDGE_ENABLED=false

# Public USDC mint (SPL Token, 6 decimals).
# For Circle devnet USDC, use: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_PUBLIC_USDC_MINT=REPLACE_WITH_PUBLIC_DEMO_USDC_MINT

# Server-only bridge config (do NOT prefix with NEXT_PUBLIC)
# RPC used by the API routes to build partially-signed transactions.
BRIDGE_SOLANA_RPC_URL=https://api.devnet.solana.com
BRIDGE_PUBLIC_DECIMALS=6
BRIDGE_CONFIDENTIAL_DECIMALS=9

# Escrow signer for public token custody + unwrap payouts.
# Accepts a file path (local) or inline JSON array (Vercel): [12,34,...]
BRIDGE_ESCROW_KEYPAIR_PATH=keys/payroll-authority.json

# Mint authority for the confidential USDC mint (used to mint on wrap).
# Accepts a file path (local) or inline JSON array (Vercel): [12,34,...]
BRIDGE_CONFIDENTIAL_USDC_MINT_AUTHORITY_KEYPAIR_PATH=keys/payroll-authority.json

# Destination confidential USDC mint
NEXT_PUBLIC_CONFIDENTIAL_USDC_MINT=REPLACE_WITH_CONFIDENTIAL_USDC_MINT
# Server-only override (optional)
# BRIDGE_CONFIDENTIAL_USDC_MINT=4FVrX...

# Escrow's Inco token account (receives confidential tokens on unwrap)
# Create once via: `node app/scripts/create-bridge-escrow-confidential-account.cjs`
BRIDGE_CONFIDENTIAL_ESCROW_TOKEN_ACCOUNT=REPLACE_WITH_ESCROW_INCO_TOKEN_ACCOUNT
