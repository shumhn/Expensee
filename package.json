{
  "name": "private-payroll-v2",
  "version": "0.1.0",
  "description": "Private real-time payroll on Solana (Inco + MagicBlock)",
  "keywords": [
    "solana",
    "privacy",
    "payroll",
    "web3",
    "defi"
  ],
  "author": "Expensee Team",
  "license": "MIT",
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "anchor build && cd frontend && npm run build",
    "test": "anchor test",
    "lint": "cd frontend && npm run lint",
    "deploy": "anchor deploy",
    "keeper:dev": "set -a && . backend/keeper/.env && set +a && npx ts-node --prefer-ts-exts -P backend/keeper/tsconfig.json backend/keeper/src/index.ts",
    "umbra:relay:dev": "node services/umbra-relay/server.cjs",
    "umbra:relay:self-test": "node services/umbra-relay/self-test.cjs",
    "privacy:purge": "node frontend/scripts/purge-v2-privacy.cjs"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.8.3",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-react": "^0.15.35",
    "@solana/wallet-adapter-react-ui": "^0.9.35",
    "@solana/wallet-adapter-wallets": "^0.19.32",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.30",
    "mocha": "^11.7.5",
    "tailwindcss": "^4.2.1",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.3.3"
  }
}
