# Keeper RPC + program
KEEPER_RPC_URL=https://devnet-router.magicblock.app
KEEPER_ROUTER_RPC_URL=https://devnet-router.magicblock.app
KEEPER_READ_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# Optional explicit ordered failover list (comma-separated).
# If unset, keeper uses KEEPER_READ_RPC_URL then KEEPER_READ_RPC_FALLBACK_URL.
#KEEPER_READ_RPC_URLS=https://devnet.helius-rpc.com/?api-key=YOUR_KEY,https://api.devnet.solana.com
KEEPER_READ_RPC_FALLBACK_URL=https://api.devnet.solana.com
KEEPER_PROGRAM_ID=REPLACE_WITH_DEPLOYED_PAYROLL_PROGRAM_ID

# Keeper signer (choose one)
# 1) Path to keypair JSON array file
KEEPER_PAYER_KEYPAIR_PATH=~/.config/solana/id.json
# 2) Inline JSON array secret key
# KEEPER_PAYER_SECRET_JSON=[12,34,...]

# MagicBlock
# Optional override. Defaults to global Magic context account.
KEEPER_MAGIC_CONTEXT=
KEEPER_MAGIC_CORE_PROGRAM_ID=Magic11111111111111111111111111111111111111
KEEPER_DELEGATION_PROGRAM_ID=DELeGGvXpWV2fqJUhqcF5ZSYMS4JTLjteaAMARRSaeSh
# Backward compatibility: if set, KEEPER_MAGIC_PROGRAM_ID is treated as delegation program.
KEEPER_VALIDATOR=MEUGGrYPxKk17hCr7wpT6s8dtNokZj5U2L57vjYMS8e

# Inco
KEEPER_INCO_LIGHTNING_ID=5sjEbPiqgZrYwR31ahR6Uk9wf5awoX61YGg7jExQSwaj
KEEPER_INCO_TOKEN_PROGRAM_ID=4cyJHzecVWuU2xux6bCAPAhALKQT8woBh4Vx3AGEGe5N

# Scheduler
KEEPER_TICK_SECS=10
KEEPER_STREAM_JITTER_MS=800
KEEPER_MAX_STREAMS_PER_TICK=25
KEEPER_MAX_RETRIES=3
KEEPER_RETRY_BASE_MS=500
KEEPER_MAX_CONSECUTIVE_FAILURES=10
KEEPER_UNDELEGATE_WAIT_ATTEMPTS=30
KEEPER_UNDELEGATE_WAIT_MS=1000
KEEPER_UNDELEGATE_RETRY_COOLDOWN_SECS=45
# After processing a withdraw request on base layer, optionally re-delegate the stream (if it was delegated).
KEEPER_REDELEGATE_AFTER_WITHDRAW=true
# If a stream is delegated, attempt to checkpoint accrual inside ER before commit+undelegate.
KEEPER_ACCRUE_ON_ER_BEFORE_COMMIT=true
# Debug-only: logs decrypted payout amounts in keeper output (do not use in production).
KEEPER_LOG_PLAINTEXT_AMOUNTS=false

# If a stream is delegated to tee.magicblock.app, you may need an auth token.
# (Avoid delegating to TEE on devnet unless you have one.)
# KEEPER_TEE_AUTH_TOKEN=REPLACE_WITH_TEE_TOKEN

# Compliance fail-closed
KEEPER_COMPLIANCE_ENABLED=false
# Only required if KEEPER_COMPLIANCE_ENABLED=true
# KEEPER_RANGE_API_KEY=REPLACE_WITH_RANGE_API_KEY
KEEPER_COMPLIANCE_POLICY_WINDOW_SECS=600
# true: pause config on any compliance error; false: pause only on confirmed high-risk/sanctions
KEEPER_PAUSE_ON_COMPLIANCE_SOFT_FAIL=false

# Ops
KEEPER_DEAD_LETTER_FILE=services/keeper/dead-letter.log
# Optional webhook endpoint for failures
# KEEPER_ALERT_WEBHOOK_URL=https://hooks.example.com/keeper
