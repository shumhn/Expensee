# Relay server
UMBRA_RELAY_PORT=9191
UMBRA_RELAY_API_KEY=
UMBRA_RELAY_JOB_PREFIX=umbra

# Modes:
# - destination: return configured destination token account
# - defer: accept route and defer claim
# - umbra-network: enable /forward-claim and try forwarding signed tx to Umbra relayer network
UMBRA_RELAY_MODE=destination
UMBRA_RELAY_DESTINATION_TOKEN_ACCOUNT=
# If true, relay creates a fresh confidential destination token account per route call.
UMBRA_RELAY_PROVISION_ONE_TIME_DESTINATION=true
UMBRA_RELAY_RPC_URL=https://api.devnet.solana.com
UMBRA_RELAY_PAYER_KEYPAIR_PATH=
# UMBRA_RELAY_PAYER_SECRET_JSON=[1,2,...]
UMBRA_RELAY_INCO_TOKEN_PROGRAM_ID=4cyJHzecVWuU2xux6bCAPAhALKQT8woBh4Vx3AGEGe5N
UMBRA_RELAY_INCO_LIGHTNING_ID=5sjEbPiqgZrYwR31ahR6Uk9wf5awoX61YGg7jExQSwaj
UMBRA_RELAY_PAYUSD_MINT=
# Optional owner for newly provisioned destination accounts.
# If unset, relay uses a random owner per route account (better unlinkability).
UMBRA_RELAY_ROUTE_OWNER_PUBKEY=

# Umbra network forwarding (used when UMBRA_RELAY_MODE=umbra-network)
UMBRA_NETWORK_DISCOVERY_URL=https://relayer.umbraprivacy.com
UMBRA_NETWORK_FORWARD_BASE_URL=https://relayer.umbraprivacy.com/relay/{relayer}
# json_transaction | json_signed_transaction | raw_base64
UMBRA_NETWORK_FORWARD_BODY_MODE=json_transaction
UMBRA_NETWORK_FORWARD_TIMEOUT_MS=8000
UMBRA_NETWORK_FORWARD_RETRIES=3
UMBRA_NETWORK_RELAYER_INDEX_MAX=8
